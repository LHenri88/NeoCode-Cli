{
  "name": "mmos-sistema-clonagem",
  "version": "0.1.0",
  "description": "MMOs - Sistema de Clonagem Autônoma de Especialistas Virtuais",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "libs/*"
  ],
  "scripts": {
    "dev:api": "cd apps/api && npm run dev",
    "dev:cli": "cd apps/cli && npx tsx src/index.ts",
    "dev:dashboard": "cd apps/dashboard && npm run dev",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "setup": "npm install && npm run build",
    "cli": "npx tsx apps/cli/src/index.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mmos",
    "ai-clones",
    "specialist-squads",
    "cognitive-architecture"
  ],
  "license": "MIT",
  "dependencies": {
    "date-fns": "^4.1.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
