name: Build Standalone Binaries

on:
  release:
    types: [created, published]
  workflow_dispatch:
    inputs:
      version:
        description: 'Version tag (e.g., v0.1.8)'
        required: false
        default: 'latest'

jobs:
  build:
    name: Build ${{ matrix.platform }} Binary
    runs-on: ${{ matrix.os }}
    strategy:
      matrix:
        include:
          - os: windows-latest
            platform: windows
            artifact: neocode-windows-x64.exe
          - os: ubuntu-latest
            platform: linux
            artifact: neocode-linux-x64
          - os: macos-latest
            platform: macos
            artifact: neocode-macos-*

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Setup Bun
        uses: oven-sh/setup-bun@v2
        with:
          bun-version: latest

      - name: Install dependencies
        run: bun install --frozen-lockfile

      - name: Build regular distribution
        run: bun run build

      - name: Build standalone binary
        run: bun run build:standalone:${{ matrix.platform }}

      - name: List generated files
        run: |
          ls -lh bin-standalone/

      - name: Test binary
        run: |
          if [ "${{ matrix.platform }}" = "windows" ]; then
            ./bin-standalone/neocode-windows-x64.exe --version
          elif [ "${{ matrix.platform }}" = "linux" ]; then
            chmod +x bin-standalone/neocode-linux-x64
            ./bin-standalone/neocode-linux-x64 --version
          else
            chmod +x bin-standalone/neocode-macos-*
            ./bin-standalone/neocode-macos-x64 --version || ./bin-standalone/neocode-macos-arm64 --version
          fi
        shell: bash

      - name: Calculate checksums
        run: |
          cd bin-standalone
          if [ "${{ matrix.platform }}" = "windows" ]; then
            sha256sum neocode-windows-x64.exe > neocode-windows-x64.exe.sha256
          elif [ "${{ matrix.platform }}" = "linux" ]; then
            sha256sum neocode-linux-x64 > neocode-linux-x64.sha256
          else
            sha256sum neocode-macos-* > checksums.txt
          fi
        shell: bash

      - name: Upload artifacts
        uses: actions/upload-artifact@v4
        with:
          name: neocode-${{ matrix.platform }}-standalone
          path: bin-standalone/*
          retention-days: 90

      - name: Upload to release (if release event)
        if: github.event_name == 'release'
        uses: softprops/action-gh-release@v1
        with:
          files: bin-standalone/*
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

  create-universal-macos:
    name: Create Universal macOS Binary
    runs-on: macos-latest
    needs: build
    if: github.event_name == 'release'
    steps:
      - name: Download macOS artifacts
        uses: actions/download-artifact@v4
        with:
          name: neocode-macos-standalone
          path: macos-binaries

      - name: Create universal binary
        run: |
          lipo -create \
            macos-binaries/neocode-macos-x64 \
            macos-binaries/neocode-macos-arm64 \
            -output neocode-macos-universal
          chmod +x neocode-macos-universal

      - name: Test universal binary
        run: ./neocode-macos-universal --version

      - name: Calculate checksum
        run: sha256sum neocode-macos-universal > neocode-macos-universal.sha256

      - name: Upload universal binary to release
        uses: softprops/action-gh-release@v1
        with:
          files: |
            neocode-macos-universal
            neocode-macos-universal.sha256
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

  sign-and-notarize:
    name: Sign and Notarize macOS Binaries
    runs-on: macos-latest
    needs: build
    if: github.event_name == 'release' && vars.ENABLE_MACOS_SIGNING == 'true'
    steps:
      - name: Download macOS artifacts
        uses: actions/download-artifact@v4
        with:
          name: neocode-macos-standalone
          path: macos-binaries

      - name: Import certificates
        uses: apple-actions/import-codesign-certs@v3
        with:
          p12-file-base64: ${{ secrets.MACOS_CERTIFICATE }}
          p12-password: ${{ secrets.MACOS_CERTIFICATE_PASSWORD }}

      - name: Sign binaries
        run: |
          for binary in macos-binaries/neocode-macos-*; do
            codesign --force --sign "${{ secrets.MACOS_IDENTITY }}" \
              --options runtime --timestamp \
              --entitlements entitlements.plist \
              "$binary"
          done

      - name: Notarize binaries
        run: |
          for binary in macos-binaries/neocode-macos-*; do
            ditto -c -k --keepParent "$binary" "$binary.zip"
            xcrun notarytool submit "$binary.zip" \
              --apple-id "${{ secrets.NOTARIZATION_APPLE_ID }}" \
              --password "${{ secrets.NOTARIZATION_PASSWORD }}" \
              --team-id "${{ secrets.NOTARIZATION_TEAM_ID }}" \
              --wait
            xcrun stapler staple "$binary"
          done

      - name: Upload signed binaries to release
        uses: softprops/action-gh-release@v1
        with:
          files: macos-binaries/neocode-macos-*
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

  create-release-manifest:
    name: Create Release Manifest
    runs-on: ubuntu-latest
    needs: [build, create-universal-macos]
    if: github.event_name == 'release'
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Download all artifacts
        uses: actions/download-artifact@v4
        with:
          path: artifacts

      - name: Create release manifest
        run: |
          cat > release-manifest.json <<EOF
          {
            "version": "${{ github.ref_name }}",
            "released_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
            "platforms": {
              "windows": {
                "x64": {
                  "file": "neocode-windows-x64.exe",
                  "sha256": "$(cat artifacts/neocode-windows-standalone/neocode-windows-x64.exe.sha256 | cut -d' ' -f1)"
                }
              },
              "linux": {
                "x64": {
                  "file": "neocode-linux-x64",
                  "sha256": "$(cat artifacts/neocode-linux-standalone/neocode-linux-x64.sha256 | cut -d' ' -f1)"
                }
              },
              "macos": {
                "x64": {
                  "file": "neocode-macos-x64",
                  "sha256": "$(grep neocode-macos-x64 artifacts/neocode-macos-standalone/checksums.txt | cut -d' ' -f1)"
                },
                "arm64": {
                  "file": "neocode-macos-arm64",
                  "sha256": "$(grep neocode-macos-arm64 artifacts/neocode-macos-standalone/checksums.txt | cut -d' ' -f1)"
                },
                "universal": {
                  "file": "neocode-macos-universal",
                  "sha256": "$(cat neocode-macos-universal.sha256 2>/dev/null | cut -d' ' -f1 || echo 'pending')"
                }
              }
            },
            "notes": "Standalone binaries require no Node.js installation. See STANDALONE_BUILD.md for details."
          }
          EOF

      - name: Upload manifest to release
        uses: softprops/action-gh-release@v1
        with:
          files: release-manifest.json
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
